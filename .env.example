# URL pública da API (usada no client-side e em SSR quando rodando localmente)
NEXT_PUBLIC_API_URL=http://localhost:3000

# URL interna da API (usada no SSR dentro do Docker — aponta para o serviço 'api')
API_URL=http://api:3000

# NextAuth — gere com: openssl rand -base64 32
NEXTAUTH_SECRET=change-me-in-production

# URL base do site admin (necessário para NextAuth callbacks)
NEXTAUTH_URL=http://localhost:3001

# WhatsApp número configurado via painel (fallback)
NEXT_PUBLIC_WHATSAPP_NUMBER=5511999999999
